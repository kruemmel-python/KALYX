>>     --mode affine `
>>     --k 16 `
>>     --xmin -8 `
>>     --xmax 8 `
>>     --backend opencl `
>>     --kernel kernels\kdna_eval.cl `
>>     --chunk 262144
>>
>>   $KN = [UInt64]((Get-Item ".\GenomeOutFull\$C`_k16_kdna.u64").Length / 8)
>>   if ($KN -ne $N) {
>>     throw "KDNA symbol count mismatch for $C : raw=$N kdna=$KN"
>>   }
>> }
